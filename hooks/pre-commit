#!/usr/bin/env sh
# Pre-commit hook — wired via `git config core.hooksPath hooks` (a one-time,
# per-clone opt-in; git won't auto-enable a tracked hooks directory). Runs
# this repository's lint/test scripts before a commit is accepted, per the
# constitution's Pre-commit Enforcement standard. Runs with cwd at the repo
# root, same as git invokes any hook. Aborts on the first failure and names
# it — never runs the rest.

set -e

# The two lints run first (fast), then every regression test — discovered by
# glob, never an enumerated list: a new scripts/test-*.sh is enforced here the
# moment it exists, in the same commit that adds its CI job, with no list to
# remember to extend. (An enumerated list here silently fell four scripts
# behind CI once — constitution v1.1.0's amendment replaced it with this
# rule.) test-hooks-pre-commit.sh running *inside* the hook means the hook
# tests its own control flow against fixtures on every commit — expected,
# not recursion.

for check in scripts/lint-docs.sh scripts/lint-project.sh scripts/test-*.sh; do
  if ! "./$check"; then
    echo "pre-commit: $check failed — commit blocked" >&2
    exit 1
  fi
done

exit 0
